{
  "manifest_version": 3,
  "name": "Rapid Lister Pro",
  "version": "2.0.0",
  "description": "AI Auto Publish for Facebook Marketplace - Batch Listing Tool",
  "permissions": ["storage", "activeTab", "scripting", "tabs", "alarms"],
  "host_permissions": ["https://www.facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["https://www.facebook.com/marketplace/*"],
    "js": ["content.js"],
    "run_at": "document_end"
  }]
}
